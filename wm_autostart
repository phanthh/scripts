#!/bin/sh

# shared

de_daemons() {
	ibus-daemon -drxR & # ibus
}

wm_daemons() {
	dbus-update-activation-environment --systemd WAYLAND_DISPLAY XDG_CURRENT_DESKTOP &
	wl-paste --watch cliphist store & # clipboard manager
	dunst &                           # notification
	swayidle -w timeout 300 'swaylock -f' before-sleep 'playerctl pause' before-sleep 'swaylock -f' &
	sway-audio-idle-inhibit &
	gammastep -l 60.2:24.6 -t 6500:3600 -v &
}

applications() {
	util_browse &
	# thunderbird &
	# telegram-desktop &
	spotify &
	slack &
	discord &
}

case "$SESSION" in
sway)
	de_daemons &
	wm_daemons &
	applications &
	sworkstyle &
	;;
labwc)
	de_daemons &
	wm_daemons &
	applications &
	;;
# gnome)
# 	de_daemons &
# 	;;
# plasma)
# 	de_daemons &
# 	;;
shell)
	;;
esac &

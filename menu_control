#!/bin/sh

mode=$(echo "’ĆŻ  lock
’üī  sleep
’üĪ  logout
’Ćæ  poweroff
’ŗ¬  reboot
" | menu_cmd -i -p '’Ćō' | awk '{ print $2 }')

[ -z "$mode" ] && exit 1

case "$mode" in
lock) swaylock ;;
sleep) systemctl suspend ;;
